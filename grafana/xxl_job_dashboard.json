{
  "uid": "xxl-job-exporter",
  "title": "XXL-JOB Overview",
  "tags": [
    "xxl-job",
    "scheduler"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "任務總數",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "count(xxl_job_job_trigger_status)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "啟用中任務",
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(xxl_job_job_trigger_status)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "在線執行器實例",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(xxl_job_executor_online_count)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "今日成功",
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "xxl_job_today_executions{status=\"success\"}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "今日失敗",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "xxl_job_today_executions{status=\"fail\"}",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "執行中",
      "gridPos": {
        "x": 20,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none"
      },
      "targets": [
        {
          "expr": "sum(xxl_job_job_running_executions) or vector(0)",
          "refId": "A",
          "instant": true
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "近 5 分鐘失敗次數（依任務）",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 12,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (app_name, job_id, job_desc) (xxl_job_job_executions{status=\"fail\", window=\"5m\"}) > 0 or sum by (app_name, job_id, job_desc) (xxl_job_job_executions{status=\"fail\", window=\"5m\"} * 0)",
          "legendFormat": "{{app_name}}/{{job_desc}} (id={{job_id}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "近 5 分鐘成功次數（依任務）",
      "gridPos": {
        "x": 12,
        "y": 4,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 12,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "sum by (app_name, job_id, job_desc) (xxl_job_job_executions{status=\"success\", window=\"5m\"})",
          "legendFormat": "{{app_name}}/{{job_desc}} (id={{job_id}})",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "成功執行平均耗時（近 1 小時窗）",
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 12,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "xxl_job_job_duration_seconds_avg{window=\"1h\"}",
          "legendFormat": "{{app_name}}/{{job_desc}}",
          "refId": "A"
        },
        {
          "expr": "xxl_job_job_duration_seconds_max{window=\"1h\"}",
          "legendFormat": "max {{app_name}}/{{job_desc}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "執行中 / 卡住偵測",
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 12,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "xxl_job_job_running_executions",
          "legendFormat": "running {{app_name}}/{{job_desc}}",
          "refId": "A"
        },
        {
          "expr": "xxl_job_job_longest_running_seconds",
          "legendFormat": "最久執行秒數 {{job_desc}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "執行器在線 vs 註冊數",
      "gridPos": {
        "x": 0,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 12,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "xxl_job_executor_online_count",
          "legendFormat": "online {{app_name}}",
          "refId": "A"
        },
        {
          "expr": "xxl_job_executor_registered_count",
          "legendFormat": "registered {{app_name}}",
          "refId": "B"
        }
      ]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "xxl_job_log 表大小",
      "gridPos": {
        "x": 12,
        "y": 20,
        "w": 12,
        "h": 8
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "fillOpacity": 12,
            "showPoints": "never"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "expr": "xxl_job_log_table_rows_estimate",
          "legendFormat": "估計筆數",
          "refId": "A"
        },
        {
          "expr": "xxl_job_log_table_size_bytes",
          "legendFormat": "bytes",
          "refId": "B"
        }
      ]
    },
    {
      "id": 13,
      "type": "table",
      "title": "任務健康狀態（距上次成功）",
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 9
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 86400
              },
              {
                "color": "red",
                "value": 172800
              }
            ]
          },
          "custom": {
            "cellOptions": {
              "type": "color-text"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "displayName": "Value",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "expr": "time() - xxl_job_job_last_success_timestamp_seconds",
          "legendFormat": "",
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "renameByName": {
              "Value": "距上次成功(秒)",
              "app_name": "執行器群組",
              "job_desc": "任務",
              "job_id": "ID",
              "handler": "Handler"
            }
          }
        }
      ]
    }
  ],
  "templating": {
    "list": [
      {
        "name": "app_name",
        "label": "執行器群組",
        "type": "query",
        "datasource": null,
        "query": "label_values(xxl_job_job_trigger_status, app_name)",
        "includeAll": true,
        "multi": true,
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        }
      }
    ]
  },
  "annotations": {
    "list": []
  }
}