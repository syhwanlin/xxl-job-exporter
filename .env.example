# ===== 資料庫連線（必填）=====
XXL_JOB_DB_HOST=your-mysql-host
XXL_JOB_DB_PORT=3306
XXL_JOB_DB_USER=xxl_job_exporter
XXL_JOB_DB_PASSWORD=change-me
# 或改用檔案掛載（K8s Secret 友善），優先於 XXL_JOB_DB_PASSWORD：
# XXL_JOB_DB_PASSWORD_FILE=/etc/xxl-job-exporter/db-password
XXL_JOB_DB_NAME=xxl_job

# ===== Exporter 行為（皆有預設值，可省略）=====
EXPORTER_LISTEN_ADDRESS=0.0.0.0
EXPORTER_LISTEN_PORT=9588

# 執行次數/耗時的統計時間窗（逗號分隔，支援 s/m/h/d）
EXPORTER_WINDOWS=5m,1h,24h

# last_success / last_fail / running 掃描的回看範圍（限制大表查詢成本）
EXPORTER_LOOKBACK=7d

# 執行器心跳超時（xxl-job 的 DEAD_TIMEOUT 為 90 秒）
EXPORTER_HEARTBEAT_TIMEOUT=90s

# >0 時：在此秒數內重複 scrape 直接回傳快取，保護資料庫
# （多套 Prometheus 同時抓同一個 exporter 時建議設 15~30）
EXPORTER_CACHE_TTL=0

# 標籤選項
EXPORTER_INCLUDE_JOB_DESC=true
EXPORTER_INCLUDE_HANDLER=true
EXPORTER_LABEL_MAX_LENGTH=120
# 超大叢集若 executor 實例非常多，可關閉逐實例心跳指標以降低 cardinality
EXPORTER_PER_INSTANCE_HEARTBEAT=true

# DB 逾時與日誌
XXL_JOB_DB_CONNECT_TIMEOUT=5
XXL_JOB_DB_READ_TIMEOUT=10
EXPORTER_LOG_LEVEL=INFO
